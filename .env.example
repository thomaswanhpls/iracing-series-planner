# Turso (LibSQL) — https://turso.tech
# Create a database: turso db create iracing-series-planner
# Get URL:          turso db show iracing-series-planner --url
# Get token:        turso db tokens create iracing-series-planner
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# iRacing OAuth (Step 11 — leave blank until OAuth app is approved)
IRACING_CLIENT_ID=
IRACING_CLIENT_SECRET=
IRACING_REDIRECT_URI=http://localhost:3000/auth/callback

# Session encryption key (Step 11 — generate with: openssl rand -base64 32)
SESSION_SECRET=
